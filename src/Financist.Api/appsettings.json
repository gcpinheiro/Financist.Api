{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=financist;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "Financist",
    "Audience": "Financist.Client",
    "Key": "change-this-development-jwt-key-with-at-least-32-characters",
    "ExpirationMinutes": 60
  },
  "Storage": {
    "DocumentsPath": "storage/documents"
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": ""
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
